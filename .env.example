# ────────────────────────────────────────────────────────────────────
# SAB Landing — Variables de entorno
# ────────────────────────────────────────────────────────────────────
# ESTE archivo es el TEMPLATE: NO poner secretos reales aquí.
# Copiar a `.env` y llenar con los valores reales SOLO en el servidor.
# El `.env` real NUNCA se commitea (verificar `.gitignore`).
# ────────────────────────────────────────────────────────────────────

# Entorno
NODE_ENV=production
PORT=3000
BASE_URL=https://sindicatoargentinodeboleros.com.ar
# Orígenes CORS adicionales (separados por coma). Los dominios principales
# (sindicatoargentinodeboleros.com.ar + localhost:3000) ya están hardcodeados.
# Agregar acá si se accede desde otra URL (ej. IP directa durante deploy).
ALLOWED_ORIGINS=

# Base de datos
DATABASE_URL=file:/app/prisma/prod.db

# Session (generar con: openssl rand -hex 32)
SESSION_SECRET=REPLACE_WITH_RANDOM_32_BYTES

# MercadoPago (panel MP → Tus integraciones → Credenciales de producción)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret del webhook: panel MP → Webhooks → Configurar notificaciones → Clave secreta.
# Sin este valor seteado, el webhook rechaza todo (las compras se procesan igual
# por el fallback cron syncPagosPendientes cada 60s + polling cliente).
MP_WEBHOOK_SECRET=REPLACE_WITH_MP_WEBHOOK_SECRET
# User ID del merchant SAB: panel MP → Tu perfil → User ID (número largo).
# Opcional pero recomendado — previene que un webhook firmado de otra cuenta MP
# afecte compras del SAB.
MP_USER_ID=REPLACE_WITH_MP_USER_ID

# SMTP (Gmail App Password o cualquier servidor SMTP compatible con nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_BREVO_SMTP_USER
SMTP_PASS=REPLACE_WITH_BREVO_SMTP_KEY
EMAIL_FROM=sindicatoargentinodeboleros@gmail.com
EMAIL_FROM_NAME=Sindicato Argentino de Boleros

# Admin del backoffice (hash bcrypt en DB, estas variables son solo para el seed inicial)
# Cambiar el ADMIN_PASS por uno fuerte y luego borrarlo del .env del servidor.
# El código del seed (prisma/seed.js) lee ADMIN_EMAIL y ADMIN_PASS — los nombres
# tienen que coincidir exactamente, no usar ADMIN_USER.
ADMIN_EMAIL=REPLACE_WITH_ADMIN_EMAIL
ADMIN_PASS=REPLACE_WITH_STRONG_PASS_MIN_16_CHARS

# Supabase — solo lectura de la tabla `waitlist_socios` desde el dashboard de
# Reportes (/api/admin/dashboard/waitlist). Si están vacías el endpoint
# devuelve {disponible:false} sin romper la página.
# - SUPABASE_URL: URL del proyecto, formato https://<ref>.supabase.co
# - SUPABASE_KEY: anon key si la tabla permite SELECT vía RLS pública (caso
#   típico en este proyecto, ya que el frontend la usa con anon), o service
#   key si querés saltearte RLS.
SUPABASE_URL=
SUPABASE_KEY=

# Rate limiting (opcionales — defaults razonables en src/middleware/rate-limit.js)
# RATE_LIMIT_LOGIN_MAX: intentos permitidos en /api/auth/login por ventana de 15 min. Default: 10.
# RATE_LIMIT_COMPRAS_MAX: requests permitidas en /api/compras/preferencia por minuto. Default: 20.
# Subir si hay falsos positivos con tráfico legítimo alto (ej. campaña con muchos compradores simultáneos).
# RATE_LIMIT_LOGIN_MAX=10
# RATE_LIMIT_COMPRAS_MAX=20
