generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Home {
  id             Int      @id @default(autoincrement())
  slider1Url     String   @default("")
  slider2Url     String   @default("")
  slider3Url     String   @default("")
  textoEvento    String   @default("")
  youtubeUrl     String   @default("")
  // Stats del proyecto — editables desde backoffice, renderizados en trust bar + Quiénes Somos
  totalEdiciones Int      @default(0)
  totalShows     Int      @default(0)
  totalPersonas  Int      @default(0)
  // Defaults globales para los box "El Evento" en home pública. Son la línea
  // de fallback cuando el evento destacado no trae overrides propios.
  boxLugar           String @default("Espacio Doble T")
  boxDireccion       String @default("Calle 23 entre 43 y 44, Barrio La Loma")
  boxCiudad          String @default("La Plata")
  boxEtiquetaEntrada String @default("Anticipada online")
  updatedAt      DateTime @updatedAt
}

model Evento {
  id            Int               @id @default(autoincrement())
  nombre        String
  descripcion   String
  fecha         DateTime
  hora          String
  invitado      String            @default("")
  flyerUrl      String            @default("")
  esDestacado   Boolean           @default(false)
  estaPublicado Boolean           @default(false)
  estaAgotado   Boolean           @default(false)
  esExterno     Boolean           @default(false)
  linkExterno   String?
  // Overrides opcionales para los box "El Evento" en home pública. Si están
  // vacíos, el frontend cae a lo derivado del evento (fecha/hora/precio) o a
  // los defaults de Home (lugar/ciudad/etiquetaEntrada).
  boxDiaOverride             String @default("")
  boxFechaOverride           String @default("")
  boxHoraOverride            String @default("")
  boxLugarOverride           String @default("")
  boxDireccionOverride       String @default("")
  boxCiudadOverride          String @default("")
  boxPrecioOverride          String @default("")
  boxEtiquetaEntradaOverride String @default("")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  compras       Compra[]
  tandas        Tanda[]
  cupones       CuponDescuento[]
  reportTokens  ReportAccessToken[]
}

model Tanda {
  id               Int       @id @default(autoincrement())
  eventoId         Int
  evento           Evento    @relation(fields: [eventoId], references: [id])
  nombre           String
  precio           Int
  orden            Int
  activa           Boolean   @default(true)
  capacidad        Int?
  cantidadVendida  Int       @default(0)
  fechaLimite      DateTime?
  porcentajeAporte Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  compras          Compra[]

  @@unique([eventoId, orden])
}

model Compra {
  id                 Int         @id @default(autoincrement())
  eventoId           Int
  evento             Evento      @relation(fields: [eventoId], references: [id])
  tandaId            Int?
  tanda              Tanda?      @relation(fields: [tandaId], references: [id])
  email              String
  nombre             String
  apellido           String
  telefono           String      @default("")
  cantidadEntradas   Int
  precioUnitario     Int
  totalPagado        Int
  tipoEntrada        String      @default("base")
  excedenteUnitario  Int         @default(0)
  mpPreferenciaId    String      @default("")
  mpPagoId           String      @default("")
  mpEstado           String      @default("pending")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  entradas           Entrada[]
  cuponUsos          CuponUso[]
}

model Entrada {
  id         Int       @id @default(autoincrement())
  compraId   Int
  compra     Compra    @relation(fields: [compraId], references: [id])
  codigoQR   String    @unique
  qrImageUrl String
  validada   Boolean   @default(false)
  validadaAt DateTime?
  createdAt  DateTime  @default(now())
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  apellido  String
  email     String   @unique
  telefono  String   @default("")
  password  String
  rol       Int      @default(2)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CuponDescuento {
  id            Int        @id @default(autoincrement())
  eventoId      Int
  evento        Evento     @relation(fields: [eventoId], references: [id])
  codigo        String     @unique
  tipo          String
  valor         Int
  topeUsos      Int?
  usosActuales  Int        @default(0)
  validoHasta   DateTime?
  activo        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  usos          CuponUso[]
}

model CuponUso {
  id                Int            @id @default(autoincrement())
  cuponId           Int
  cupon             CuponDescuento @relation(fields: [cuponId], references: [id])
  compraId          Int
  compra            Compra         @relation(fields: [compraId], references: [id])
  descuentoAplicado Int
  createdAt         DateTime       @default(now())

  @@unique([compraId])
}

// Token de acceso de solo-lectura a un Reporte de Ventas por Evento (#9).
// Habilita un link público (sin sesión) acotado a UN evento, con expiración
// obligatoria y revocable. Modela el mismo patrón que CuponDescuento (token
// @unique + activo + ventana de validez). El endpoint público que valida este
// token solo expone métricas AGREGADAS del evento — nunca PII de compradores.
model ReportAccessToken {
  id           Int       @id @default(autoincrement())
  eventoId     Int
  evento       Evento    @relation(fields: [eventoId], references: [id])
  token        String    @unique
  expiraEn     DateTime
  creadoPor    String    @default("")
  activo       Boolean   @default(true)
  ultimoAcceso DateTime?
  createdAt    DateTime  @default(now())

  @@index([eventoId])
}
